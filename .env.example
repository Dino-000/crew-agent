APP_NAME=trello-crew-playground
POLL_INTERVAL_SECONDS=60

# Trello Configuration
TRELLO_API_KEY=your_trello_api_key
TRELLO_TOKEN=your_trello_token
TRELLO_BOARD_ID=your_board_id
TRELLO_TO_DO_LIST_NAME=To Do
TRELLO_IN_PROGRESS_LIST_NAME=In Progress
TRELLO_DONE_LIST_NAME=Done

# Local LLM (Ollama) - RECOMMENDED
USE_LOCAL_LLM=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Cloud LLM (OpenAI) - Optional fallback (only needed if USE_LOCAL_LLM=false)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# CrewAI Settings
USE_CREWAI=true

# Output Configuration
OUTPUT_DIR=output
STATE_FILE=data/state.json
COMMENT_DELIVERY_MODE=both
MAX_COMMENT_CHARS=3500
