# App
APP_NAME=trello-crew-playground
TRIGGER_MODE=webhook
POLL_INTERVAL_SECONDS=60
VERIFY_TRELLO_SIGNATURE=true

# Trello
TRELLO_API_KEY=
TRELLO_TOKEN=
TRELLO_SECRET=
TRELLO_BOARD_ID=
TRELLO_TO_DO_LIST_NAME=To Do
TRELLO_IN_PROGRESS_LIST_NAME=In Progress
TRELLO_DONE_LIST_NAME=Done
TRELLO_WEBHOOK_CALLBACK_URL=http://localhost:8000/webhook/trello

# LLM
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Local output
OUTPUT_DIR=output
STATE_FILE=data/state.json
COMMENT_DELIVERY_MODE=both
MAX_COMMENT_CHARS=3500
